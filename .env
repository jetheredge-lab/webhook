# App
NODE_ENV=production
APP_PORT=3001
APP_SECRET=35658fb7d4f2318dbacb9112faf5066e45b73e10352026bc49a6733b6a3fb3aa   # AES-256 + JWT signing
WEBHOOK_SECRET=dadc86f7ddae62961ebbc5829d855d50               # HMAC-SHA256 webhook verification

# PostgreSQL Base Settings (These build the Database and the Docker Container natively)
POSTGRES_USER=trade_admin
POSTGRES_PASSWORD=0a3644687543ecfe897b35e57b97f68cffb3331ad8f791eb
POSTGRES_DB=tradovate_bridge

# This evaluates using the above variables so they never mismatch
DATABASE_URL=postgresql://${POSTGRES_USER}:${POSTGRES_PASSWORD}@postgres:5432/${POSTGRES_DB}?schema=public

# Redis
REDIS_URL=redis://redis:6379

# Tradovate (can be overridden per-account in DB)
TRADOVATE_API_URL_DEMO=https://demo.tradovateapi.com/v1
TRADOVATE_API_URL_LIVE=https://live.tradovateapi.com/v1
TRADOVATE_WS_URL_DEMO=wss://demo.tradovateapi.com/v1/websocket
TRADOVATE_WS_URL_LIVE=wss://live.tradovateapi.com/v1/websocket

# Dashboard Auth
DASHBOARD_USERNAME=admin
DASHBOARD_PASSWORD=password123

# Production TLS (prod only)
DOMAIN=your-domain.com
CERTBOT_EMAIL=you@example.com
