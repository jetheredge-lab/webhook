# App
NODE_ENV=development
APP_PORT=3001
APP_SECRET=change_me_32_char_min_for_aes_enc   # AES-256 + JWT signing
WEBHOOK_SECRET=change_me_webhook               # HMAC-SHA256 webhook verification

# PostgreSQL
DATABASE_URL=postgresql://user:pass@localhost:5432/tradovate_bridge

# Redis
REDIS_URL=redis://localhost:6379

# Tradovate (can be overridden per-account in DB)
TRADOVATE_API_URL_DEMO=https://demo.tradovateapi.com/v1
TRADOVATE_API_URL_LIVE=https://live.tradovateapi.com/v1
TRADOVATE_WS_URL_DEMO=wss://demo.tradovateapi.com/v1/websocket
TRADOVATE_WS_URL_LIVE=wss://live.tradovateapi.com/v1/websocket

# Dashboard Auth
DASHBOARD_USERNAME=admin
DASHBOARD_PASSWORD=password123

# Production TLS (prod only)
DOMAIN=your-domain.com
CERTBOT_EMAIL=you@example.com
